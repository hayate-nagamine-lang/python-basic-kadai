        "def calculate_total(price,tax):\n",
        "\n",
        "    total = price * (1 +tax / 100)\n",
        "    return total\n",
        "\n",
        "result = calculate_total(110,10)\n",
        "\n",
        "print(f\"合計金額は{result}円です\")\n",
        "\n",
